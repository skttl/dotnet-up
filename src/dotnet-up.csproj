<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>dotnet-up</AssemblyName>

    <PackAsTool>true</PackAsTool>
    <ToolCommandName>dotnet-up</ToolCommandName>
    <PackageId>dotnet-up</PackageId>
    <Version>1.0.5</Version>
    <Authors>skttl</Authors>
    <Description>Launch all your local development processes in parallel from a dotnet-up.json config file.</Description>
    <PackageTags>tool;dev;runner;process;watch</PackageTags>
    <PackageProjectUrl>https://github.com/skttl/dotnet-up</PackageProjectUrl>
    <RepositoryUrl>https://github.com/skttl/dotnet-up</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageOutputPath>../nupkg</PackageOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <None Include="../README.md" Pack="true" PackagePath="\" />
    <None Include="../schema/dotnet-up.schema.json" Pack="true" PackagePath="content\" />
  </ItemGroup>

</Project>
